{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",          // ← change from "commonjs" to "ESNext"
    "moduleResolution": "bundler", // ← change from "node" to "bundler" (Vite uses bundler)
    "lib": ["dom", "dom.iterable", "esnext"],
    "noImplicitAny": false,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]  // ← add "vite/client" for import.meta.env types
  },
  "include": [
    "src",
    "tests",
    "**/*.ts",
    "**/*.tsx",
    "**/*.jsx"
  ]
}